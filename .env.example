TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
SHADOW_SIZE_USD=10

# Maximum slippage (in cents) before Telegram alerts are suppressed.
# Slippage = (current best ask - leader's fill price) * 100 for BUYs,
#           (leader's fill price - current best bid) * 100 for SELLs.
# Set to a high value (e.g. 100) to disable the filter.
# Default 3 = filter out alerts where price has moved more than 3¢.
SLIPPAGE_ALERT_MAX_CENTS=3
